# ==============================================================================
# IDE Services 离线环境 - 镜像版本与凭据
# 修改后需重新执行 docker compose up -d
# ==============================================================================

# --- 镜像版本（离线环境请使用已 docker load 到本机的镜像 tag）---
IDE_SERVICES_IMAGE=docker.io/jetbrains/ide-services:2026.1.1.145
POSTGRES_IMAGE=postgres:16
MINIO_IMAGE=minio/minio:RELEASE.2024-01-16T16-07-38Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2024-01-13T08-44-48Z
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.0
NGINX_IMAGE=nginx:1.27-alpine

# --- 对外访问端口（宿主机）---
IDE_SERVICES_PORT=8080
KEYCLOAK_PORT=8085
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_PORT=5432

# --- HTTPS 反向代理（内置于 docker-compose.yml 的 reverse-proxy 服务）---
HTTPS_PORT=443
HTTP_REDIRECT_PORT=80

# --- PostgreSQL ---
POSTGRES_DB=toolbox
POSTGRES_USER=toolbox
POSTGRES_PASSWORD=toolbox_pwd

# --- MinIO (S3 兼容对象存储) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=toolbox

# --- Keycloak（离线内置认证服务）---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=toolbox
KEYCLOAK_CLIENT_ID=tbe-server
KEYCLOAK_CLIENT_SECRET=123456

# IDE Services 登录管理员邮箱（须与 Keycloak realm 中用户邮箱一致）
ROOT_ADMIN_EMAIL='这里需要填入JetBrains帐户管理员的邮箱才能激活本服务'
